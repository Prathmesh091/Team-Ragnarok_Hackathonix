# Environment Variables
# Copy this file to .env.local and fill in your values

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medichain
DB_USER=postgres
DB_PASSWORD=postgres

# Full Database URL (alternative to individual vars)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/medichain

# JWT Secret (change this in production!)
JWT_SECRET=medichain-jwt-secret-change-this-in-production

# Server Port
PORT=3000

# Blockchain Configuration
SEPOLIA_RPC_URL=your_sepolia_rpc_url_here
PRIVATE_KEY=your_private_key_here

# QRCodeAPI.io Configuration
NEXT_PUBLIC_QRCODE_API_KEY=your_qrcode_api_key_here
